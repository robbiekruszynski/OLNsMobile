{
  "expo": {
    "name": "OLNs",
    "slug": "olnsmobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/OLNs_app_logo.png",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/OLNsLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E1117"
    },
    "ios": {
      "icon": "./assets/OLNs_app_logo.png",
      "bundleIdentifier": "com.olnsmobile.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "OLNs uses Bluetooth to connect with nearby devices on the mesh",
        "NSBluetoothPeripheralUsageDescription": "OLNs uses Bluetooth to connect with nearby devices on the mesh",
        "NSLocationWhenInUseUsageDescription": "Location is used for Bluetooth peer discovery",
        "UIBackgroundModes": [
          "bluetooth-central",
          "bluetooth-peripheral"
        ]
      }
    },
    "android": {
      "icon": "./assets/OLNs_app_logo.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/OLNs_app_logo.png",
        "backgroundColor": "#0E1117"
      },
      "package": "com.olnsmobile.app",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "plugins": [
      "expo-dev-client",
      [
        "react-native-permissions",
        {
          "iosPermissions": [
            "Bluetooth"
          ]
        }
      ],
      "expo-font",
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "b14f1142-5cb0-4705-98cf-6b30492947d1"
      }
    }
  }
}
